# Ignore everything by default
**

# Include only what we need
!dist/extension.js
!package.json
!README.md
!CHANGELOG.md
!LICENSE
!images/**/*.png
!images/**/*.svg
!media/**/*.svg
!brand.config.json

# Include webview UI build (React app) - must include the folder structure
!webview-ui/
!webview-ui/build/
!webview-ui/build/**
!webview-ui/build/assets/
!webview-ui/build/assets/**

# Explicitly exclude source files that might be under webview-ui
webview-ui/src/**
webview-ui/node_modules/**
webview-ui/*.ts
webview-ui/*.json
webview-ui/*.config.*

# Exclude dev/build files from root
.vscode/**
src/**
node_modules/**
installer/**
scripts/**
docs/**
*.ts
*.map
.gitignore
tsconfig.json
package-lock.json
*.vsix
dist/installers/**
