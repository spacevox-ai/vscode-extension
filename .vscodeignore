# Ignore everything by default
**

# Include only what we need
!dist/extension.js
!package.json
!README.md
!CHANGELOG.md
!LICENSE
!images/**/*.png
!images/**/*.svg
!media/**/*.svg
!brand.config.json

# Include webview UI build (React app)
!webview-ui/build/**

# Exclude dev/build files
.vscode/**
src/**
node_modules/**
installer/**
scripts/**
docs/**
*.ts
*.map
.gitignore
tsconfig.json
package-lock.json
*.vsix
dist/installers/**
