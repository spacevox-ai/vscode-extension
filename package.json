{
  "name": "work-studio-ai",
  "displayName": "work.studio AI",
  "description": "AI-powered code completion, chat, and governance for enterprise teams",
  "version": "0.1.0",
  "publisher": "workstudio",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/workstudio/vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "code completion",
    "copilot",
    "chat",
    "work.studio",
    "mcp",
    "enterprise",
    "governance"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "workstudio.chat",
        "fullName": "work.studio AI",
        "name": "workstudio",
        "description": "AI assistant for coding, debugging, and code explanation",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code or concept"
          },
          {
            "name": "fix",
            "description": "Fix bugs or issues in the selected code"
          },
          {
            "name": "test",
            "description": "Generate tests for the selected code"
          },
          {
            "name": "docs",
            "description": "Generate documentation for the selected code"
          },
          {
            "name": "refactor",
            "description": "Suggest refactoring improvements"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "workstudio.login",
        "title": "work.studio: Sign In"
      },
      {
        "command": "workstudio.logout",
        "title": "work.studio: Sign Out"
      },
      {
        "command": "workstudio.selectEnvironment",
        "title": "work.studio: Select Environment"
      },
      {
        "command": "workstudio.showStatus",
        "title": "work.studio: Show Connection Status"
      },
      {
        "command": "workstudio.toggleCompletion",
        "title": "work.studio: Toggle Code Completion"
      },
      {
        "command": "workstudio.openChat",
        "title": "work.studio: Open Chat"
      },
      {
        "command": "workstudio.openChatPanel",
        "title": "work.studio: Open Chat Panel",
        "icon": "$(comment-discussion)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workstudio",
          "title": "work.studio",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "workstudio": [
        {
          "type": "webview",
          "id": "workStudio.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "configuration": {
      "title": "work.studio AI",
      "properties": {
        "workstudio.environment": {
          "type": "string",
          "enum": ["local", "staging", "production"],
          "default": "production",
          "description": "Environment preset. Overrides serverUrl and authUrl with environment-specific defaults.",
          "enumDescriptions": [
            "Local development (ws://localhost:8102, https://auth.spacevox.local)",
            "Staging (wss://api.stage.work.studio, https://auth.stage.work.studio)",
            "Production (wss://api.work.studio, https://auth.work.studio)"
          ]
        },
        "workstudio.serverUrl": {
          "type": "string",
          "default": "",
          "description": "MCP server WebSocket URL. Leave empty to use environment preset. Examples: ws://localhost:8102/ws/mcp (local), wss://api.work.studio/ws/mcp (prod)"
        },
        "workstudio.authUrl": {
          "type": "string",
          "default": "",
          "description": "Authentication server URL (Keycloak). Leave empty to use environment preset."
        },
        "workstudio.agentId": {
          "type": "string",
          "default": "",
          "description": "Agent ID for chat and completion. Leave empty to use the default VS Code agent (019d5a01-1001-7001-8001-000000000020)."
        },
        "workstudio.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI code completion"
        },
        "workstudio.completion.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay in milliseconds before requesting completion"
        },
        "workstudio.completion.maxTokens": {
          "type": "number",
          "default": 256,
          "description": "Maximum tokens for completion suggestions"
        },
        "workstudio.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable usage analytics for governance"
        },
        "workStudio.aiEndpoint": {
          "type": "string",
          "default": "",
          "description": "AI runtime endpoint URL for chat. Leave empty to use environment preset (production: https://api.work.studio, staging: https://api.stage.work.studio, local: http://localhost:8102)"
        },
        "workStudio.accountServiceUrl": {
          "type": "string",
          "default": "",
          "description": "Account service URL for identity resolution. Leave empty to use environment preset."
        },
        "workStudio.agentId": {
          "type": "string",
          "default": "019d5a01-1001-7001-8001-000000000050",
          "description": "Agent ID to use for chat (UUID)"
        },
        "workStudio.tenantId": {
          "type": "string",
          "default": "",
          "description": "Tenant ID for API requests (UUID). Usually auto-detected from authentication."
        },
        "workStudio.envId": {
          "type": "string",
          "default": "",
          "description": "Environment ID for API requests (UUID). Usually auto-detected from account."
        },
        "workStudio.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for AI runtime authentication (optional, JWT preferred)"
        },
        "workStudio.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Default AI model to use for chat"
        },
        "workStudio.brand.name": {
          "type": "string",
          "default": "",
          "description": "Override brand name (e.g., 'Acme AI Assistant')"
        },
        "workStudio.brand.shortName": {
          "type": "string",
          "default": "",
          "description": "Override short brand name (e.g., 'Acme AI')"
        },
        "workStudio.brand.accentColor": {
          "type": "string",
          "default": "",
          "description": "Override accent color (hex, e.g., '#ff5500')"
        },
        "workStudio.brand.avatarGradient": {
          "type": "string",
          "default": "",
          "description": "Override assistant avatar gradient (CSS gradient, e.g., 'linear-gradient(135deg, #ff5500, #ff8800)')"
        },
        "workStudio.brand.welcomeTitle": {
          "type": "string",
          "default": "",
          "description": "Override welcome screen title"
        },
        "workStudio.brand.welcomeHint": {
          "type": "string",
          "default": "",
          "description": "Override welcome screen hint text"
        },
        "workStudio.brand.statusBarText": {
          "type": "string",
          "default": "",
          "description": "Override status bar text"
        },
        "workStudio.brand.suggestions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "icon": { "type": "string" },
              "text": { "type": "string" },
              "action": { "type": "string" }
            }
          },
          "description": "Override suggestion buttons [{icon, text, action}, ...]"
        },
        "workStudio.brand.defaultAgentId": {
          "type": "string",
          "default": "",
          "description": "Override default agent UUID"
        }
      }
    },
    "keybindings": [
      {
        "command": "workstudio.triggerCompletion",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "workstudio.openChat",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "cd webview-ui && npm ci && npm run build && cd .. && npm run compile",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "build:webview": "cd webview-ui && npm ci && npm run build",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish",
    "install-local": "code --install-extension work-studio-ai-*.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "ws": "^8.14.2",
    "keytar": "^7.9.0"
  }
}
